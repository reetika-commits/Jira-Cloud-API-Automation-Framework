            {
              "name": "Create_issue",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "pm.collectionVariables.set(\"issueSummary\", pm.variables.get(\"issueSummary\"));"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const response=pm.response.json()\r",
                      "pm.collectionVariables.set(\"CreatedIssueID\", response.id)\r",
                      "pm.collectionVariables.set(\"CreatedIssueKey\", response.key)\r",
                      "pm.test(\"Status code is 201\", function () {\r",
                      "    pm.response.to.have.status(201);\r",
                      "});\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "basic",
                  "basic": [
                    {
                      "key": "password",
                      "value": "ATATT3xFfGF0W836VvftcLYlPPY9cIQuPbNr7mN2YbiZTyV8X-H2mv4m3hDTwM_wyEGxXLMnEik4T-lLI2LOoKvb864uztkU7vLpVCgSzn0LhFmNB3fV4nOB4W6OTMkn1pavijzwZ6_dXWvQvIpRFRArG16fn8ywjJoc4R9bXfYwmgL1MDUwW-o=0D17BC24",
                      "type": "string"
