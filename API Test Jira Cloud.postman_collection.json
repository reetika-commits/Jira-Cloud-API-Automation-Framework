                      "key": "username",
                      "value": "{{Jira_UserName}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n  \"fields\": {\r\n    \"issuetype\": {\r\n      \"id\": \"{{IssueID}}\"\r\n    },\r\n    \"labels\": [\r\n      \"bugfix\",\r\n      \"blitz_test\"\r\n    ],\r\n    \"project\": {\r\n      \"id\": \"{{ProjectID}}\"\r\n    },\r\n    \"reporter\": {\r\n      \"id\": \"{{ReporterID}}\"\r\n    },\r\n    \"summary\": \"{{issueSummary}}\"\r\n    },\r\n  \"update\": {}\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
